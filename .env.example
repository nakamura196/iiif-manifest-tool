# Site Configuration
# ==================
# Site URL - Used for sitemap generation, OGP meta tags, and absolute URLs
# In production, set this to your actual domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Authentication (Firebase Auth)
# ==============================
# NextAuth URL - Used for IIIF auth redirects and base URL references
NEXTAUTH_URL=http://localhost:3000

# Firebase Configuration (Client-side)
# =====================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# S3-Compatible Object Storage
# ============================
# For storing IIIF images and assets
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_BUCKET_NAME=your-bucket-name

# IIIF Configuration
# ==================
# JWT secret for IIIF Auth API
# Generate using: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here-change-in-production

# IIIF API Version (2 or 3, default: 3)
IIIF_API_VERSION=3